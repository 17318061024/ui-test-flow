      "position": {
        "x": 100,
        "y": 200
      }
    },
    {
      "id": "ai_navigate",
      "type": "AIAction",
      "label": "AI 打开登录页",
      "position": {
        "x": 280,
        "y": 200
      },
      "aiAction": {
        "prompt": "导航到登录页面 https://example.com/login",
        "timeout": 30000
      }
    },
    {
      "id": "ai_input_user",
      "type": "AIAction",
      "label": "AI 输入用户名",
      "position": {
        "x": 460,
        "y": 200
      },
      "aiAction": {
        "prompt": "在用户名输入框中输入 ${username}",
        "timeout": 15000
      }
    },
    {
      "id": "ai_input_pwd",
      "type": "AIAction",
      "label": "AI 输入密码",
      "position": {
        "x": 640,
        "y": 200
      },
      "aiAction": {
        "prompt": "在密码输入框中输入 ${password}",
        "timeout": 15000
      }
    },
    {
      "id": "ai_click_login",
      "type": "AIAction",
      "label": "AI 点击登录",
      "position": {
        "x": 820,
        "y": 200
      },
      "aiAction": {
        "prompt": "点击登录按钮",
        "timeout": 15000
      }
    },
    {
      "id": "ai_assert",
      "type": "AIAssert",
      "label": "AI 验证登录成功",
      "position": {
        "x": 1000,
        "y": 200
      },
      "aiAssert": {
        "prompt": "页面显示登录成功的欢迎信息或用户头像",
        "timeout": 30000
      }
    },
    {
      "id": "ai_extract",
      "type": "AIQuery",
      "label": "AI 提取用户信息",
      "position": {
        "x": 1180,
        "y": 200
      },
      "aiQuery": {
        "prompt": "获取当前登录用户的名称",
        "schema": "string",
        "as": "currentUser"
      }
    },
