{
  "id": "dynamic-form-test-flow",
  "name": "动态表单测试流程",
  "description": "基于提取的动态数据进行表单填写和验证，包含用户名提取、地址选择、数据验证等复杂场景",
  "version": 1,
  "tags": [
    "表单",
    "动态数据",
    "变量",
    "复杂场景"
  ],
  "author": "UI Test Flow",
  "nodes": [
    {
      "id": "node-1",
      "type": "Start",
      "label": "开始表单测试",
      "position": {
        "x": 100,
        "y": 100
      }
    },
    {
      "id": "node-2",
      "type": "Navigate",
      "label": "打开注册页面",
      "position": {
        "x": 100,
        "y": 200
      },
      "navigate": {
        "prompt": "打开用户注册页面",
        "url": "https://demo.example.com/register",
        "timeout": 30
      }
    },
    {
      "id": "node-3",
      "type": "Wait",
      "label": "等待表单加载",
      "position": {
        "x": 100,
        "y": 300
      },
      "wait": {
        "prompt": "等待注册表单完全加载",
        "timeout": 15
      }
    },
    {
      "id": "node-4",
      "type": "Extract",
      "label": "提取可用用户名",
      "position": {
        "x": 100,
        "y": 400
      },
      "extract": {
        "prompt": "提取页面上显示的推荐用户名或可用用户名列表",
        "as": "recommendedUsername"
      }
    },
    {
      "id": "node-5",
      "type": "Action",
      "label": "输入用户名",
      "position": {
        "x": 100,
        "y": 500
      },
      "action": {
        "prompt": "使用提取的推荐用户名填入用户名输入框",
        "value": "$recommendedUsername",
        "isVariable": true,
        "timeout": 10
      }
    },
    {
      "id": "node-6",
      "type": "Action",
      "label": "输入密码",
      "position": {
        "x": 100,
        "y": 600
      },
      "action": {
        "prompt": "在密码输入框输入密码",
        "value": "Test@123456",
        "isVariable": false,
        "timeout": 5
      }
    },
    {
      "id": "node-7",
      "type": "Action",
      "label": "确认密码",
      "position": {
        "x": 100,
        "y": 700
      },
      "action": {
        "prompt": "在确认密码框再次输入相同密码",
        "value": "Test@123456",
        "isVariable": false,
        "timeout": 5
      }
    },
    {
      "id": "node-8",
      "type": "Extract",
      "label": "提取邮箱域名",
      "position": {
        "x": 100,
        "y": 800
      },
      "extract": {
        "prompt": "提取邮箱输入框的占位符或建议域名",
        "as": "emailDomain"
      }
    },
    {
      "id": "node-9",
      "type": "Action",
      "label": "组合邮箱地址",
      "position": {
        "x": 100,
        "y": 900
      },
      "action": {
        "prompt": "使用用户名和域名组合完整的邮箱地址",
        "value": "$recommendedUsername@$emailDomain",
        "isVariable": true,
        "timeout": 5
      }
    },
    {
      "id": "node-10",
      "type": "Action",
      "label": "输入邮箱",
      "position": {
        "x": 100,
        "y": 1000
      },
      "action": {
        "prompt": "在邮箱输入框输入组合的邮箱地址",
        "value": "$recommendedUsername@$emailDomain",
        "isVariable": true,
        "timeout": 5
      }
    },
    {
      "id": "node-11",
      "type": "Action",
      "label": "输入手机号",
      "position": {
        "x": 100,
        "y": 1100
      },
      "action": {
        "prompt": "",
        "value": "",
        "isVariable": false,
        "timeout": 5,
        "target": ""
      }
    },
    {
      "id": "node-12",
      "type": "Extract",
      "label": "提取可选地区",
      "position": {
        "x": 100,
        "y": 1200
      },
      "extract": {
        "prompt": "提取地区选择器的所有可用选项",
        "as": "availableRegions"
      }
    },
    {
      "id": "node-13",
      "type": "Action",
      "label": "选择省份",
      "position": {
        "x": 100,
        "y": 1300
      },
      "action": {
        "prompt": "从提取的地区列表中选择第一个省份",
        "value": "$availableRegions[0]",
        "isVariable": true,
        "timeout": 10
      }
    },
    {
      "id": "node-14",
      "type": "Wait",
      "label": "等待城市列表",
      "position": {
        "x": 100,
        "y": 1400
      },
      "wait": {
        "prompt": "等待城市下拉列表加载",
        "timeout": 5
      }
    },
    {
      "id": "node-15",
      "type": "Extract",
      "label": "提取城市列表",
      "position": {
        "x": 100,
        "y": 1500
      },
      "extract": {
        "prompt": "提取城市下拉列表的所有选项",
        "as": "cityList"
      }
    },
    {
      "id": "node-16",
      "type": "Condition",
      "label": "检查城市数量",
      "position": {
        "x": 100,
        "y": 1600
      },
      "condition": {
        "prompt": "检查提取的城市列表是否有数据"
      }
    },
    {
      "id": "node-17",
      "type": "Action",
      "label": "选择城市",
      "position": {
        "x": 50,
        "y": 1720
      },
      "action": {
        "prompt": "从城市列表中选择第一个城市",
        "value": "$cityList[0]",
        "isVariable": true,
        "timeout": 10
      }
    },
    {
      "id": "node-18",
      "type": "Action",
      "label": "选择默认城市",
      "position": {
        "x": 200,
        "y": 1600
      },
      "action": {
        "prompt": "选择默认城市选项",
        "timeout": 10
      }
    },
    {
      "id": "node-19",
      "type": "Wait",
      "label": "等待区县加载",
      "position": {
        "x": 100,
        "y": 1840
      },
      "wait": {
        "prompt": "等待区县下拉列表加载",
        "timeout": 5
      }
    },
    {
      "id": "node-20",
      "type": "Extract",
      "label": "提取详细地址模板",
      "position": {
        "x": 100,
        "y": 1960
      },
      "extract": {
        "prompt": "提取页面上显示的详细地址填写示例或模板",
        "as": "addressTemplate"
      }
    },
    {
      "id": "node-21",
      "type": "Action",
      "label": "输入详细地址",
      "position": {
        "x": 100,
        "y": 2080
      },
      "action": {
        "prompt": "根据提取的地址模板变量 $addressTemplate 填入详细地址信息",
        "value": "$addressTemplate",
        "isVariable": true,
        "timeout": 10
      }
    },
    {
      "id": "node-22",
      "type": "Action",
      "label": "输入邮政编码",
      "position": {
        "x": 100,
        "y": 2200
      },
      "action": {
        "prompt": "输入邮政编码",
        "value": "100000",
        "isVariable": false,
        "timeout": 5
      }
    },
    {
      "id": "node-23",
      "type": "Extract",
      "label": "提取默认生日",
      "position": {
        "x": 100,
        "y": 2320
      },
      "extract": {
        "prompt": "提取生日选择器的默认日期或范围",
        "as": "birthdayRange"
      }
    },
    {
      "id": "node-24",
      "type": "Action",
      "label": "选择生日",
      "position": {
        "x": 100,
        "y": 2440
      },
      "action": {
        "prompt": "使用提取的生日范围变量 $birthdayRange 选择生日",
        "value": "$birthdayRange",
        "isVariable": true,
        "timeout": 10
      }
    },
    {
      "id": "node-25",
      "type": "Extract",
      "label": "提取性别选项",
      "position": {
        "x": 100,
        "y": 2560
      },
      "extract": {
        "prompt": "提取性别单选框的所有选项",
        "as": "genderOptions"
      }
    },
    {
      "id": "node-26",
      "type": "Action",
      "label": "选择性别",
      "position": {
        "x": 100,
        "y": 2680
      },
      "action": {
        "prompt": "从性别选项中选择第一个",
        "value": "$genderOptions[0]",
        "isVariable": true,
        "timeout": 5
      }
    },
    {
      "id": "node-27",
      "type": "Condition",
      "label": "检查是否需要验证码",
      "position": {
        "x": 100,
        "y": 2800
      },
      "condition": {
        "prompt": "检查页面上是否有验证码输入框"
      }
    },
    {
      "id": "node-28",
      "type": "Extract",
      "label": "提取验证码",
      "position": {
        "x": 50,
        "y": 2920
      },
      "extract": {
        "prompt": "提取页面上显示的验证码文本",
        "as": "captchaCode"
      }
    },
    {
      "id": "node-29",
      "type": "Action",
      "label": "输入验证码",
      "position": {
        "x": 50,
        "y": 3040
      },
      "action": {
        "prompt": "输入提取的验证码",
        "value": "$captchaCode",
        "isVariable": true,
        "timeout": 5
      }
    },
    {
      "id": "node-30",
      "type": "Action",
      "label": "跳过验证码",
      "position": {
        "x": 200,
        "y": 2800
      },
      "action": {
        "prompt": "如果没有验证码，点击获取验证码或跳过验证",
        "timeout": 5
      }
    },
    {
      "id": "node-31",
      "type": "Action",
      "label": "勾选用户协议",
      "position": {
        "x": 100,
        "y": 3160
      },
      "action": {
        "prompt": "勾选已阅读并同意用户协议",
        "timeout": 5
      }
    },
    {
      "id": "node-32",
      "type": "Action",
      "label": "点击注册按钮",
      "position": {
        "x": 100,
        "y": 3280
      },
      "action": {
        "prompt": "点击注册按钮提交表单",
        "timeout": 15
      }
    },
    {
      "id": "node-33",
      "type": "Wait",
      "label": "等待注册结果",
      "position": {
        "x": 100,
        "y": 3400
      },
      "wait": {
        "prompt": "等待注册结果或页面跳转",
        "timeout": 15
      }
    },
    {
      "id": "node-34",
      "type": "Assert",
      "label": "验证注册成功",
      "position": {
        "x": 100,
        "y": 3520
      },
      "assert": {
        "prompt": "验证页面显示注册成功或跳转到了个人中心",
        "timeout": 10
      }
    },
    {
      "id": "node-35",
      "type": "Extract",
      "label": "提取新用户ID",
      "position": {
        "x": 100,
        "y": 3640
      },
      "extract": {
        "prompt": "提取新注册用户的ID或用户名",
        "as": "newUserId"
      }
    },
    {
      "id": "node-36",
      "type": "Action",
      "label": "进入个人资料页",
      "position": {
        "x": 100,
        "y": 3760
      },
      "action": {
        "prompt": "点击进入个人资料或账户设置页面",
        "timeout": 10
      }
    },
    {
      "id": "node-37",
      "type": "Wait",
      "label": "等待资料页加载",
      "position": {
        "x": 100,
        "y": 3880
      },
      "wait": {
        "prompt": "等待个人资料页面加载",
        "timeout": 10
      }
    },
    {
      "id": "node-38",
      "type": "Extract",
      "label": "验证注册信息",
      "position": {
        "x": 100,
        "y": 4000
      },
      "extract": {
        "prompt": "提取页面显示的用户名、邮箱、手机号，与填入的信息进行对比",
        "as": "registeredInfo"
      }
    },
    {
      "id": "node-39",
      "type": "Condition",
      "label": "验证信息匹配",
      "position": {
        "x": 100,
        "y": 4120
      },
      "condition": {
        "prompt": "检查提取的注册信息是否与填入的信息一致"
      }
    },
    {
      "id": "node-40",
      "type": "Assert",
      "label": "验证信息正确",
      "position": {
        "x": 50,
        "y": 4240
      },
      "assert": {
        "prompt": "验证个人资料页面显示的用户信息与注册时填写的一致",
        "timeout": 10
      }
    },
    {
      "id": "node-41",
      "type": "Action",
      "label": "记录不匹配项",
      "position": {
        "x": 200,
        "y": 4240
      },
      "action": {
        "prompt": "记录信息不匹配的具体项到日志",
        "timeout": 5
      }
    },
    {
      "id": "node-42",
      "type": "Action",
      "label": "截图保存",
      "position": {
        "x": 100,
        "y": 4360
      },
      "action": {
        "prompt": "截取最终的个人资料页面",
        "timeout": 5
      }
    },
    {
      "id": "node-43",
      "type": "End",
      "label": "测试完成",
      "position": {
        "x": 100,
        "y": 4480
      }
    }
