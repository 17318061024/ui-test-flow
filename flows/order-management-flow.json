{
  "id": "order-management-flow",
  "name": "订单管理流程",
  "description": "订单的查询、查看详情、取消、申请售后等完整管理流程",
  "version": 1,
  "tags": [
    "订单",
    "售后",
    "管理",
    "复杂场景"
  ],
  "author": "UI Test Flow",
  "nodes": [
    {
      "id": "node-1",
      "type": "Start",
      "label": "开始",
      "position": {
        "x": 100,
        "y": 100
      }
    },
    {
      "id": "node-2",
      "type": "Navigate",
      "label": "打开订单页面",
      "position": {
        "x": 100,
        "y": 200
      },
      "navigate": {
        "prompt": "打开电商网站的我的订单页面",
        "timeout": 30
      }
    },
    {
      "id": "node-3",
      "type": "Wait",
      "label": "等待订单列表",
      "position": {
        "x": 100,
        "y": 300
      },
      "wait": {
        "prompt": "等待订单列表页面完全加载",
        "timeout": 15
      }
    },
    {
      "id": "node-4",
      "type": "Condition",
      "label": "检查是否需要登录",
      "position": {
        "x": 100,
        "y": 400
      },
      "condition": {
        "prompt": "检查页面是否跳转到登录页面"
      }
    },
    {
      "id": "node-5",
      "type": "Action",
      "label": "登录账号",
      "position": {
        "x": 50,
        "y": 520
      },
      "action": {
        "prompt": "在登录页面输入用户名和密码，点击登录",
        "timeout": 15
      }
    },
    {
      "id": "node-6",
      "type": "Wait",
      "label": "等待登录跳转",
      "position": {
        "x": 50,
        "y": 640
      },
      "wait": {
        "prompt": "等待登录成功后跳转到订单页面",
        "timeout": 15
      }
    },
    {
      "id": "node-7",
      "type": "Assert",
      "label": "验证订单列表",
      "position": {
        "x": 150,
        "y": 400
      },
      "assert": {
        "prompt": "验证页面显示订单列表或空状态提示",
        "timeout": 10
      }
    },
    {
      "id": "node-8",
      "type": "Extract",
      "label": "提取订单统计",
      "position": {
        "x": 150,
        "y": 520
      },
      "extract": {
        "prompt": "提取页面上显示的订单数量统计（全部订单、待付款、待发货等）",
        "as": "orderStats"
      }
    },
    {
      "id": "node-9",
      "type": "Condition",
      "label": "检查是否有订单",
      "position": {
        "x": 150,
        "y": 640
      },
      "condition": {
        "prompt": "检查订单列表是否有订单数据"
      }
    },
