      "id": "node-10",
      "type": "Extract",
      "label": "提取订单列表",
      "position": {
        "x": 80,
        "y": 760
      },
      "extract": {
        "prompt": "提取前10个订单的订单号、商品名称、订单状态、订单金额",
        "as": "orderList"
      }
    },
    {
      "id": "node-11",
      "type": "Action",
      "label": "点击第一个订单",
      "position": {
        "x": 80,
        "y": 880
      },
