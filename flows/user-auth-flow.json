{
  "id": "user-auth-flow",
  "name": "用户注册登录流程",
  "description": "完整的用户注册、邮箱验证、登录及个人信息管理流程",
  "version": 1,
  "tags": ["用户", "注册", "登录", "认证", "复杂场景"],
  "author": "UI Test Flow",
  "nodes": [
    {
      "id": "node-1",
      "type": "Start",
      "label": "开始",
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "node-2",
      "type": "Navigate",
      "label": "打开注册页面",
      "position": { "x": 100, "y": 200 },
      "navigate": {
        "prompt": "打开任意网站的用户注册页面",
        "timeout": 30
      }
    },
    {
      "id": "node-3",
      "type": "Wait",
      "label": "等待页面加载",
      "position": { "x": 100, "y": 300 },
      "wait": {
        "prompt": "等待注册表单页面完全加载",
        "timeout": 10
      }
    },
    {
      "id": "node-4",
      "type": "Assert",
      "label": "验证注册表单",
      "position": { "x": 100, "y": 400 },
      "assert": {
        "prompt": "验证页面显示用户名、邮箱、密码、确认密码等注册表单字段",
        "timeout": 10
      }
    },
    {
      "id": "node-5",
      "type": "Action",
      "label": "输入用户名",
      "position": { "x": 100, "y": 500 },
      "action": {
        "prompt": "在用户名输入框输入 testuser001",
        "timeout": 5
      }
    },
    {
      "id": "node-6",
      "type": "Action",
      "label": "输入邮箱",
      "position": { "x": 100, "y": 600 },
      "action": {
        "prompt": "在邮箱输入框输入 testuser001@example.com",
        "timeout": 5
      }
    },
    {
      "id": "node-7",
      "type": "Action",
      "label": "输入密码",
      "position": { "x": 100, "y": 700 },
      "action": {
        "prompt": "在密码输入框输入 Test@123456",
        "timeout": 5
      }
    },
    {
      "id": "node-8",
      "type": "Action",
      "label": "确认密码",
      "position": { "x": 100, "y": 800 },
      "action": {
        "prompt": "在确认密码输入框再次输入 Test@123456",
        "timeout": 5
      }
    },
    {
      "id": "node-9",
      "type": "Condition",
      "label": "检查是否有验证码",
      "position": { "x": 100, "y": 900 },
      "condition": {
        "prompt": "检查页面上是否有验证码或滑块验证"
      }
    },
    {
      "id": "node-10",
      "type": "Action",
      "label": "完成滑块验证",
      "position": { "x": 50, "y": 1020 },
      "action": {
        "prompt": "如果有滑块验证，完成滑块验证操作",
        "timeout": 10
      }
    },
    {
      "id": "node-11",
      "type": "Action",
      "label": "点击注册按钮",
      "position": { "x": 250, "y": 900 },
      "action": {
        "prompt": "点击注册或创建账号按钮",
        "timeout": 10
      }
    },
    {
      "id": "node-12",
      "type": "Wait",
      "label": "等待注册结果",
      "position": { "x": 150, "y": 1140 },
      "wait": {
        "prompt": "等待注册结果或跳转",
        "timeout": 15
      }
    },
    {
      "id": "node-13",
      "type": "Condition",
      "label": "检查注册结果",
      "position": { "x": 150, "y": 1260 },
      "condition": {
        "prompt": "检查是否注册成功或需要邮箱验证"
      }
    },
    {
      "id": "node-14",
      "type": "Assert",
      "label": "验证注册成功",
      "position": { "x": 50, "y": 1380 },
      "assert": {
        "prompt": "验证页面显示注册成功或邮箱验证提示",
        "timeout": 10
      }
    },
    {
      "id": "node-15",
      "type": "Extract",
      "label": "提取验证链接",
      "position": { "x": 50, "y": 1500 },
      "extract": {
        "prompt": "如果页面显示邮箱验证链接，提取验证链接地址",
        "as": "verificationLink"
      }
    },
    {
      "id": "node-16",
      "type": "Action",
      "label": "模拟邮箱验证",
      "position": { "x": 50, "y": 1620 },
      "action": {
        "prompt": "模拟点击邮箱验证链接完成验证（实际测试中可能需要打开邮箱）",
        "timeout": 10
      }
    },
    {
      "id": "node-17",
      "type": "Wait",
      "label": "等待验证完成",
      "position": { "x": 50, "y": 1740 },
      "wait": {
        "prompt": "等待邮箱验证完成页面",
        "timeout": 10
      }
    },
    {
      "id": "node-18",
      "type": "Assert",
      "label": "验证邮箱已验证",
      "position": { "x": 50, "y": 1860 },
      "assert": {
        "prompt": "验证页面显示邮箱验证成功或账号已激活",
        "timeout": 10
      }
    },
    {
      "id": "node-19",
      "type": "Navigate",
      "label": "打开登录页面",
      "position": { "x": 350, "y": 1260 },
      "navigate": {
        "prompt": "打开网站的登录页面",
        "timeout": 15
      }
    },
    {
      "id": "node-20",
      "type": "Wait",
      "label": "等待登录页加载",
      "position": { "x": 350, "y": 1380 },
      "wait": {
        "prompt": "等待登录表单页面完全加载",
        "timeout": 10
      }
    },
    {
      "id": "node-21",
      "type": "Action",
      "label": "输入用户名",
      "position": { "x": 350, "y": 1500 },
      "action": {
        "prompt": "在用户名或邮箱输入框输入 testuser001",
        "timeout": 5
      }
    },
    {
      "id": "node-22",
      "type": "Action",
      "label": "输入密码",
      "position": { "x": 350, "y": 1620 },
      "action": {
        "prompt": "在密码输入框输入 Test@123456",
        "timeout": 5
      }
    },
    {
      "id": "node-23",
      "type": "Condition",
      "label": "检查记住登录",
      "position": { "x": 350, "y": 1740 },
      "condition": {
        "prompt": "检查是否有记住登录状态的复选框"
      }
    },
    {
      "id": "node-24",
      "type": "Action",
      "label": "勾选记住登录",
      "position": { "x": 300, "y": 1860 },
      "action": {
        "prompt": "勾选记住我或记住登录状态",
        "timeout": 3
      }
    },
    {
      "id": "node-25",
      "type": "Action",
      "label": "点击登录",
      "position": { "x": 400, "y": 1860 },
      "action": {
        "prompt": "点击登录按钮",
        "timeout": 10
      }
    },
    {
      "id": "node-26",
      "type": "Wait",
      "label": "等待登录跳转",
      "position": { "x": 350, "y": 1980 },
      "wait": {
        "prompt": "等待登录成功后的页面跳转",
        "timeout": 15
      }
    },
    {
      "id": "node-27",
      "type": "Assert",
      "label": "验证登录成功",
      "position": { "x": 350, "y": 2100 },
      "assert": {
        "prompt": "验证页面显示用户已登录，显示用户头像或用户名",
        "timeout": 10
      }
    },
    {
      "id": "node-28",
      "type": "Extract",
      "label": "提取用户名",
      "position": { "x": 350, "y": 2220 },
      "extract": {
        "prompt": "提取页面显示的用户名或用户信息",
        "as": "loggedInUser"
      }
    },
    {
      "id": "node-29",
      "type": "Condition",
      "label": "检查是否需要完善信息",
      "position": { "x": 350, "y": 2340 },
      "condition": {
        "prompt": "检查是否弹出完善个人资料的提示"
      }
    },
    {
      "id": "node-30",
      "type": "Action",
      "label": "完善个人信息",
      "position": { "x": 280, "y": 2460 },
      "action": {
        "prompt": "如果弹出完善资料弹窗，填写昵称、手机号等基本信息",
        "timeout": 15
      }
    },
    {
      "id": "node-31",
      "type": "Action",
      "label": "保存资料",
      "position": { "x": 280, "y": 2580 },
      "action": {
        "prompt": "点击保存或确认按钮",
        "timeout": 10
      }
    },
    {
      "id": "node-32",
      "type": "Wait",
      "label": "等待保存结果",
      "position": { "x": 280, "y": 2700 },
      "wait": {
        "prompt": "等待保存成功提示",
        "timeout": 10
      }
    },
    {
      "id": "node-33",
      "type": "Action",
      "label": "进入个人中心",
      "position": { "x": 420, "y": 2460 },
      "action": {
        "prompt": "点击用户头像或进入个人中心/账户设置",
        "timeout": 10
      }
    },
    {
      "id": "node-34",
      "type": "Wait",
      "label": "等待页面加载",
      "position": { "x": 420, "y": 2580 },
      "wait": {
        "prompt": "等待个人中心页面加载",
        "timeout": 10
      }
    },
    {
      "id": "node-35",
      "type": "Assert",
      "label": "验证个人信息",
      "position": { "x": 420, "y": 2700 },
      "assert": {
        "prompt": "验证个人中心页面显示用户注册信息",
        "timeout": 10
      }
    },
    {
      "id": "node-36",
      "type": "Extract",
      "label": "提取账户信息",
      "position": { "x": 420, "y": 2820 },
      "extract": {
        "prompt": "提取用户的注册邮箱、注册时间、会员等级等信息",
        "as": "accountInfo"
      }
    },
    {
      "id": "node-37",
      "type": "Action",
      "label": "退出登录",
      "position": { "x": 420, "y": 2940 },
      "action": {
        "prompt": "点击退出登录或注销按钮",
        "timeout": 10
      }
    },
    {
      "id": "node-38",
      "type": "Wait",
      "label": "等待退出完成",
      "position": { "x": 420, "y": 3060 },
      "wait": {
        "prompt": "等待退出成功并跳转到首页",
        "timeout": 10
      }
    },
    {
      "id": "node-39",
      "type": "Assert",
      "label": "验证已退出",
      "position": { "x": 420, "y": 3180 },
      "assert": {
        "prompt": "验证页面显示未登录状态，登录按钮可见",
        "timeout": 10
      }
    },
    {
      "id": "node-40",
      "type": "End",
      "label": "流程结束",
      "position": { "x": 350, "y": 3300 }
    }
  ],
