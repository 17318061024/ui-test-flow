{
  "name": "ui-test-flow",
  "version": "1.0.0",
  "description": "UI测试用例图谱化生成工具",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate": "tsx src/cli.ts",
    "test": "playwright test",
    "api": "tsx src/api-server.ts",
    "dev:all": "concurrently \"npm run api\" \"cd frontend && npm run dev\""
  },
  "dependencies": {
    "@midscene/web": "^1.0.0",
    "playwright": "^1.42.0",
    "js-yaml": "^4.1.0",
    "uuid": "^9.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2"
  }
}
