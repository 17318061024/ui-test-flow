{
  "name": "ui-test-flow",
  "version": "1.0.0",
  "description": "UI测试用例图谱化生成工具",
  "type": "module",
  "scripts": {
    "dev:backend": "cd backend && mvn spring-boot:run",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "generate": "tsx src/cli.ts",
    "test": "playwright test",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && mvn clean package"
  },
  "dependencies": {
    "@midscene/web": "^1.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "playwright": "^1.42.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
